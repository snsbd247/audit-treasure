# ===== SmartERP — Self-hosted Supabase (Production) =====
# Copy this to ".env.production" before running `npm run build`.
# Replace the values with the ones from your VPS install (printed by install.sh).

VITE_SUPABASE_URL="https://supabase.smarterp365.com"
VITE_SUPABASE_PUBLISHABLE_KEY="REPLACE_WITH_ANON_KEY_FROM_VPS"
VITE_SUPABASE_PROJECT_ID="self-hosted"

# Laravel API base (served from the same domain by Nginx)
VITE_API_BASE_URL="https://smarterp365.com/api"
